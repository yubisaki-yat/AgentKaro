# Internshala Auto-Apply Bot Credentials
# Rename this file to .env and put your actual credentials below
INTERNSHALA_EMAIL=your_email@example.com
INTERNSHALA_PASSWORD=your_password

# Optional: Custom generic answers for assessment questions
GITHUB_LINK=https://github.com/yourusername
PORTFOLIO_LINK=https://yourportfolio.com
LINKEDIN_LINK=https://linkedin.com/in/yourusername
YEARS_OF_EXPERIENCE=2
CURRENT_CTC=Not Applicable (Fresher/Student)
EXPECTED_CTC=As per industry standards
NOTICE_PERIOD=Can join immediately
RELOCATION=Yes

# Razorpay Integration (For Subscriptions)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX
